{
  "schema": "manifast.wireframe/1",
  "id": "screen-dashboard",
  "name": "대시보드",
  "device": "desktop",
  "size": { "w": 1440, "h": 1024 },
  "background": "#FFFFFF",
  "root": [
    {
      "id": "nav",
      "type": "Navbar",
      "frame": { "x": 0, "y": 0, "w": 1440, "h": 64 },
      "brand": "Manifast",
      "links": ["Overview", "Reports", "Settings"],
      "actions": ["Docs", "New"]
    },
    {
      "id": "side",
      "type": "Box",
      "variant": "section",
      "frame": { "x": 0, "y": 64, "w": 240, "h": 960 },
      "children": [
        { "id": "side-label", "type": "Text", "frame": { "x": 16, "y": 16, "w": 200, "h": 16 }, "content": "MENU", "role": "label" },
        { "id": "side-list", "type": "List", "frame": { "x": 12, "y": 48, "w": 216, "h": 300 }, "items": 5, "withIcon": true },
        { "id": "side-div", "type": "Divider", "frame": { "x": 12, "y": 360, "w": 216, "h": 1 } },
        { "id": "side-out", "type": "Button", "frame": { "x": 12, "y": 380, "w": 160, "h": 36 }, "label": "Sign out", "variant": "ghost" }
      ]
    },
    { "id": "title", "type": "Text", "frame": { "x": 280, "y": 88, "w": 400, "h": 36 }, "content": "Dashboard", "role": "h1" },
    { "id": "subtitle", "type": "Text", "frame": { "x": 280, "y": 128, "w": 400, "h": 16 }, "content": "Updated just now", "role": "caption" },
    { "id": "search", "type": "Input", "frame": { "x": 1020, "y": 84, "w": 360, "h": 40 }, "placeholder": "Search…", "kind": "search" },
    { "id": "tabs", "type": "Tabs", "frame": { "x": 280, "y": 168, "w": 620, "h": 40 }, "tabs": ["Overview", "Activity", "Team"], "activeIndex": 0 },
    {
      "id": "kpi",
      "type": "Box",
      "variant": "card",
      "frame": { "x": 280, "y": 228, "w": 360, "h": 180 },
      "children": [
        { "id": "kpi-label", "type": "Text", "frame": { "x": 20, "y": 20, "w": 200, "h": 16 }, "content": "Revenue", "role": "label" },
        { "id": "kpi-value", "type": "Text", "frame": { "x": 20, "y": 44, "w": 300, "h": 28 }, "content": "$12,300", "role": "h2" },
        { "id": "kpi-badge", "type": "Badge", "frame": { "x": 20, "y": 84, "w": 64, "h": 24 }, "label": "+8%", "tone": "success" },
        { "id": "kpi-div", "type": "Divider", "frame": { "x": 20, "y": 120, "w": 320, "h": 1 } },
        { "id": "kpi-note", "type": "Text", "frame": { "x": 20, "y": 136, "w": 300, "h": 16 }, "content": "vs last month", "role": "body" }
      ]
    },
    {
      "id": "profile",
      "type": "Box",
      "variant": "card",
      "frame": { "x": 680, "y": 228, "w": 360, "h": 180 },
      "children": [
        { "id": "pf-avatar", "type": "Avatar", "frame": { "x": 20, "y": 20, "w": 48, "h": 48 }, "shape": "circle" },
        { "id": "pf-name", "type": "Text", "frame": { "x": 84, "y": 24, "w": 200, "h": 20 }, "content": "Jane Doe", "role": "h3" },
        { "id": "pf-role", "type": "Text", "frame": { "x": 84, "y": 48, "w": 200, "h": 16 }, "content": "Administrator", "role": "caption" },
        { "id": "pf-toggle", "type": "Toggle", "frame": { "x": 20, "y": 90, "w": 220, "h": 24 }, "label": "Notifications", "on": true },
        { "id": "pf-check", "type": "Checkbox", "frame": { "x": 20, "y": 120, "w": 240, "h": 20 }, "label": "Weekly digest", "checked": true },
        { "id": "pf-radio-light", "type": "Radio", "frame": { "x": 20, "y": 146, "w": 110, "h": 20 }, "label": "Light", "checked": true },
        { "id": "pf-radio-dark", "type": "Radio", "frame": { "x": 140, "y": 146, "w": 110, "h": 20 }, "label": "Dark" }
      ]
    },
    { "id": "chart", "type": "Image", "frame": { "x": 1080, "y": 228, "w": 300, "h": 180 }, "ratio": "3:2", "label": "Chart" },
    { "id": "table", "type": "Table", "frame": { "x": 280, "y": 432, "w": 760, "h": 320 }, "columns": ["Name", "Status", "Owner", "Date"], "rows": 6 },
    {
      "id": "notes",
      "type": "Box",
      "variant": "card",
      "frame": { "x": 1080, "y": 432, "w": 300, "h": 320 },
      "children": [
        { "id": "nt-label", "type": "Text", "frame": { "x": 20, "y": 16, "w": 236, "h": 16 }, "content": "Quick note", "role": "label" },
        { "id": "nt-icon", "type": "Icon", "frame": { "x": 260, "y": 12, "w": 20, "h": 20 }, "name": "settings", "size": 18 },
        { "id": "nt-area", "type": "Textarea", "frame": { "x": 20, "y": 40, "w": 260, "h": 120 }, "placeholder": "Type a note…", "rows": 4 },
        { "id": "nt-select", "type": "Select", "frame": { "x": 20, "y": 172, "w": 260, "h": 62 }, "label": "Assignee", "placeholder": "Choose", "options": ["Jane", "John", "Sam"] },
        { "id": "nt-save", "type": "Button", "frame": { "x": 20, "y": 252, "w": 120, "h": 40 }, "label": "Save", "variant": "primary" },
        { "id": "nt-cancel", "type": "Button", "frame": { "x": 148, "y": 252, "w": 120, "h": 40 }, "label": "Cancel", "variant": "secondary" }
      ]
    },
    {
      "id": "activity",
      "type": "Box",
      "variant": "card",
      "frame": { "x": 280, "y": 776, "w": 760, "h": 208 },
      "children": [
        { "id": "ac-label", "type": "Text", "frame": { "x": 20, "y": 16, "w": 300, "h": 16 }, "content": "Recent activity", "role": "label" },
        { "id": "ac-list", "type": "List", "frame": { "x": 12, "y": 44, "w": 736, "h": 152 }, "items": 3, "withAvatar": true }
      ]
    },
    {
      "id": "team",
      "type": "Box",
      "variant": "card",
      "frame": { "x": 1080, "y": 776, "w": 300, "h": 208 },
      "children": [
        { "id": "tm-label", "type": "Text", "frame": { "x": 20, "y": 16, "w": 200, "h": 16 }, "content": "Team", "role": "label" },
        { "id": "tm-a1", "type": "Avatar", "frame": { "x": 20, "y": 48, "w": 44, "h": 44 }, "shape": "circle" },
        { "id": "tm-a2", "type": "Avatar", "frame": { "x": 72, "y": 48, "w": 44, "h": 44 }, "shape": "circle" },
        { "id": "tm-a3", "type": "Avatar", "frame": { "x": 124, "y": 48, "w": 44, "h": 44 }, "shape": "square" },
        { "id": "tm-caption", "type": "Text", "frame": { "x": 20, "y": 104, "w": 260, "h": 16 }, "content": "3 members online", "role": "caption" },
        { "id": "tm-invite", "type": "Button", "frame": { "x": 20, "y": 140, "w": 100, "h": 32 }, "label": "Invite", "variant": "secondary", "size": "sm" }
      ]
    }
  ]
}
