{
  "$ref": "#/definitions/Plan",
  "definitions": {
    "Plan": {
      "type": "object",
      "properties": {
        "schema": {
          "type": "string",
          "const": "manifast.plan/1"
        },
        "phases": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "name": {
                "type": "string"
              },
              "goal": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "planned",
                  "active",
                  "done"
                ],
                "default": "planned"
              },
              "taskIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "name"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "schema",
        "phases"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
