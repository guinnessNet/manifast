{
  "name": "manifast",
  "version": "1.3.2",
  "description": "Local, read-only visualizer + live-reload + export for AI-authored wireframes and dev docs (.manifast/).",
  "type": "module",
  "license": "MIT",
  "author": "kjh <kjh@maipharm.com>",
  "homepage": "https://github.com/guinnessNet/manifast#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guinnessNet/manifast.git"
  },
  "bugs": {
    "url": "https://github.com/guinnessNet/manifast/issues"
  },
  "keywords": [
    "wireframe",
    "documentation",
    "docs",
    "prd",
    "spec",
    "kanban",
    "roadmap",
    "diagram",
    "live-reload",
    "ai",
    "agent",
    "local",
    "offline",
    "cli",
    "visualizer"
  ],
  "bin": {
    "manifast": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "gen:schema": "tsx scripts/gen-schema.ts",
    "build:web": "vite build",
    "build:server": "tsx scripts/build-server.ts",
    "build": "npm run gen:schema && npm run build:web && npm run build:server",
    "check": "tsx scripts/ssr-check.tsx",
    "shots": "node scripts/shots.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "start": "node dist/cli/index.js",
    "check:readme": "node scripts/check-readme-version.mjs",
    "prepublishOnly": "npm run check:readme && npm run typecheck && npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.1",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "gray-matter": "^4.0.3",
    "mri": "^1.2.0",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "esbuild": "^0.24.0",
    "highlight.js": "^11.10.0",
    "html-to-image": "^1.11.11",
    "jsdom": "^25.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "rehype-highlight": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vitest": "^2.1.9",
    "ws": "^8.18.0",
    "zod-to-json-schema": "^3.23.5"
  }
}
